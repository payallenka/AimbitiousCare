# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Admins are decided by role: set a user's user_role to 'admin' in the DB.
# This allowlist is OPTIONAL — only a fallback to bootstrap the first admin.
VITE_SUPER_ADMIN_EMAILS=

# --- Mock payments (testing without Stripe) ---
# Auto-ON whenever STRIPE_SECRET_KEY is empty: "Pay & Book" goes to an in-app
# /mock-payment page with Success/Unsuccessful buttons, and payouts/refunds/
# onboarding are all simulated. Turns OFF automatically once a real secret key
# is set. Force it on (even with a key) by setting MOCK_PAYMENTS=true.
# MOCK_PAYMENTS=true

# --- Stripe (client) ---
# Publishable key is safe to expose to the browser.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# --- Stripe (server / Netlify Functions only — NEVER prefix with VITE_) ---
# Leave STRIPE_SECRET_KEY blank to stay in mock mode.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Supabase service-role key — used ONLY by Netlify Functions to bypass RLS.
# Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_URL=your_supabase_url_here

# Public base URL of the app (used for Stripe redirect/return URLs)
APP_URL=http://localhost:8888

# Optional: secret to protect the scheduled-jobs endpoint if invoked via HTTP
CRON_SECRET=change_me
